{
  "name": "engram",
  "version": "1.0.0",
  "description": "Plant Document Integrity System",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "concurrently \"node node_modules/vite/bin/vite.js\" \"node node_modules/wait-on/bin/wait-on http://localhost:5173 && node_modules\\electron\\dist\\electron.exe .\"",
    "dev:web": "concurrently \"node node_modules/vite/bin/vite.js\" \"node src/server/index.js\"",
    "start": "node src/server/index.js",
    "start:prod": "PORT=3000 node src/server/index.js",
    "start:sandbox": "PORT=3001 node src/server/index.js",
    "build": "vite build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "isomorphic-git": "^1.37.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "vectra": "^0.12.3",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.engram.app",
    "productName": "ENGRAM",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
