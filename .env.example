# ENGRAM server configuration
# Copy this file to .env and fill in the values.
# The server reads these at startup via process.env.

# ── Claude API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ───────────────────────────────────────────────────────────────────
# Set a random password to protect the API.
# Leave blank to disable auth (local dev only).
ENGRAM_TOKEN=change-me-before-deploying

# ── Storage ────────────────────────────────────────────────────────────────
# Absolute path to the directory where engram.db and the vector index live.
# Defaults to %APPDATA%\engram-workspace on Windows, ~/engram-workspace on Linux.
WORKSPACE_PATH=C:\engram-workspace

# ── Network ────────────────────────────────────────────────────────────────
PORT=3000
