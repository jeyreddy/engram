{
  "name": "engram",
  "version": "1.0.0",
  "description": "Plant Document Integrity System",
  "main": "src/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "isomorphic-git": "^1.37.2",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "vectra": "^0.12.3",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.engram.app",
    "productName": "ENGRAM",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      ".engram/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
